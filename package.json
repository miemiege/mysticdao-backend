{
  "name": "mysticdao-ai-backend",
  "version": "3.1.0",
  "description": "MysticDao AI Backend v2 — Local Calculation + AI Interpretation",
  "type": "module",
  "scripts": {
    "dev": "tsx src/api/server.ts",
    "start": "tsx src/api/server.ts",
    "db:init": "tsx scripts/init-db.ts",
    "db:backup": "cp data/mysticdao.db data/mysticdao.db.$(date +%Y%m%d_%H%M%S).bak && echo 'Backup created'",
    "db:analyze": "sqlite3 data/mysticdao.db 'ANALYZE' && echo 'ANALYZE completed'",
    "db:vacuum": "sqlite3 data/mysticdao.db 'VACUUM' && echo 'VACUUM completed'"
  },
  "dependencies": {
    "@types/sqlite3": "^3.1.11",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.52.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5"
  }
}
